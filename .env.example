# Copy to .env and fill in real values. NEVER commit your real .env.

# PostgreSQL connection URL.
# Format: postgres://USER:PASSWORD@HOST:PORT/DBNAME?search_path=wareg
DATABASE_URL=postgres://YOUR_DB_USER:YOUR_DB_PASSWORD@YOUR_DB_HOST:5432/YOUR_DB_NAME?search_path=wareg

# Port the web server listens on.
PORT=7001

# Optional whole-site HTTP Basic Auth. Format: user:pass,user:pass
# Leave unset/blank to disable auth (e.g. local dev). Use strong passwords and
# serve over HTTPS in production. The /healthz endpoint is always public.
AUTH_USERS=yourname:yourpassword,spouse:theirpassword

# Only used by docker-compose.yml (local Postgres container)
POSTGRES_USER=wareg
POSTGRES_PASSWORD=YOUR_POSTGRES_PASSWORD
POSTGRES_DB=wareg
